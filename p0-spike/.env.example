# Supabase project URL (Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Service role key: bypasses Storage RLS. Use only on your machine for this spike — never ship to a browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Private Storage bucket that will hold Baileys session JSON (create in Dashboard → Storage → New bucket → Private)
NMCAS_SESSION_BUCKET=nmcas-sessions

# Logical project id; objects are stored under sessions/{NMCAS_PROJECT_ID}/...
NMCAS_PROJECT_ID=p0-local-test

# Optional: when set, after a successful connection the script sends one text message to this group JID (ends with @g.us)
# NMCAS_TEST_GROUP_JID=120363123456789012@g.us
