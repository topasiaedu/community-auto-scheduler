generator client {
  provider = "prisma-client-js"
}

// Run: `npm run db:seed` from repo root (after migrate).

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  POST
  POLL
}

enum MessageStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model Project {
  id               String              @id @default(cuid())
  name             String
  description      String?
  createdAt        DateTime            @default(now())
  messages         ScheduledMessage[]
  notifyRecipients NotifyRecipient[]
  members          ProjectMember[]
}

// Links a Supabase Auth user id to a Project (see API X-Project-Id membership checks).
model ProjectMember {
  id        String   @id @default(cuid())
  // Supabase Auth user id (JWT `sub` / session `user.id`).
  userId    String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
}

model NotifyRecipient {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  waNumber  String
  label     String?

  @@index([projectId])
}

model ScheduledMessage {
  id              String        @id @default(cuid())
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groupJid        String
  groupName       String
  type            MessageType
  copyText        String?
  imageUrl        String?
  pollQuestion    String?
  pollOptions     String[]      @default([])
  pollMultiSelect Boolean       @default(false)
  scheduledAt     DateTime
  status          MessageStatus @default(PENDING)
  sentAt          DateTime?
  error           String?
  createdAt       DateTime      @default(now())

  @@index([projectId, scheduledAt])
}
