# Supabase Postgres — use Session mode (port 5432) for pg-boss + Prisma when possible; Transaction pooler (6543) can break LISTEN.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Optional: direct (non-pooler) URL for `prisma migrate` when DATABASE_URL uses PgBouncer.
# DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# API
PORT=3001
# Comma-separated browser origins allowed by the API (CORS). Add http://localhost:5174 if you ever run Vite on another port.
WEB_ORIGIN=http://localhost:5173

# Used by WA / Storage + Supabase Auth JWT verification on the API
SUPABASE_URL=https://YOUR_REF.supabase.co
# Settings → API → Project API keys → `anon` `public` (API uses this for `auth.getUser(jwt)` only).
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NMCAS_SESSION_BUCKET=nmcas-sessions

# P0 spike + Storage session prefix (Baileys session objects under sessions/{id}/)
NMCAS_PROJECT_ID=p0-local-test

# Default Prisma project id (seed with `npm run db:seed`; must match seed)
DEFAULT_PROJECT_ID=nmcas-default-project

# Private bucket for scheduled post images (separate object prefix from sessions/)
NMCAS_POST_MEDIA_BUCKET=nmcas-post-media

# First-time users: auto-create a ProjectMember row for DEFAULT_PROJECT_ID (set to false / 0 / off to disable).
AUTH_AUTO_JOIN_DEFAULT_PROJECT=true

# Worker: when a scheduled message becomes FAILED, send one WhatsApp text to this MSISDN (digits; + optional). Default: +60139968817.
# NMCAS_FAILURE_NOTIFY_MSISDN=60139968817

# Vite web app (same Supabase project). Copy into apps/web/.env if you do not load them from the repo root.
# VITE_SUPABASE_URL=https://YOUR_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=
