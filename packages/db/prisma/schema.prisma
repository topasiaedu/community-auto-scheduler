generator client {
  provider = "prisma-client-js"
}

// Run: `npm run db:seed` from repo root (after migrate).

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  POST
  POLL
}

enum MessageStatus {
  PENDING
  SENDING
  SENT
  FAILED
  DRAFT
  CANCELLED
}

enum OperatorKind {
  REMINDER
  VALUE
}

enum ValueFormat {
  IMAGE_CAPTION
  TEXT_ONLY
  POLL
}

enum ReminderFormat {
  IMAGE
  TEXT
  STICKER
}

enum ScheduleRuleKind {
  WEBINAR_DATE_OFFSET
  EVENT_START_OFFSET
}

model Project {
  id                String                  @id @default(cuid())
  name              String
  description       String?
  sopUrl                String?
  campaignNote          String?
  /// WhatsApp community JIDs for Value fan-out; null or [] = all eligible communities.
  activeCommunityJids   Json?
  createdAt             DateTime                @default(now())
  messages          ScheduledMessage[]
  notifyRecipients  NotifyRecipient[]
  members           ProjectMember[]
  userPreferences   UserProjectPreference[]
  campaigns         Campaign[]
  reminderTemplates ReminderTemplate[]
}

// Links a Supabase Auth user id to a Project (see API X-Project-Id membership checks).
model ProjectMember {
  id        String   @id @default(cuid())
  // Supabase Auth user id (JWT `sub` / session `user.id`).
  userId    String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
}

model NotifyRecipient {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  waNumber  String
  label     String?

  @@index([projectId])
}

model Campaign {
  id                String             @id @default(cuid())
  projectId         String
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  webinarDate       DateTime           @db.Date
  eventStartTimeMyt String
  reminderGroupJid  String
  reminderGroupName String
  customValues      Json
  createdAt         DateTime           @default(now())
  messages          ScheduledMessage[]

  @@index([projectId])
}

model ReminderTemplate {
  id                 String             @id @default(cuid())
  projectId          String
  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slotKey            String
  name               String
  reminderFormat     ReminderFormat
  mediaUrl           String?
  stickerUrl         String?
  bodyTemplate       String?
  scheduleRuleKind   ScheduleRuleKind
  dayOffset          Int?
  clockTimeMyt       String?
  startOffsetMinutes Int?
  sortOrder          Int
  scheduledMessages  ScheduledMessage[]

  @@unique([projectId, slotKey])
  @@index([projectId])
}

model ScheduledMessage {
  id                 String            @id @default(cuid())
  projectId          String
  project            Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groupJid           String
  groupName          String
  type               MessageType
  operatorKind       OperatorKind?
  valueFormat        ValueFormat?
  reminderFormat     ReminderFormat?
  reminderTemplateId String?
  reminderTemplate   ReminderTemplate? @relation(fields: [reminderTemplateId], references: [id], onDelete: SetNull)
  campaignId         String?
  campaign           Campaign?         @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  copyText           String?
  imageUrl           String?
  stickerUrl         String?
  pollQuestion       String?
  pollOptions        String[]          @default([])
  pollMultiSelect    Boolean           @default(false)
  scheduledAt        DateTime
  status             MessageStatus     @default(PENDING)
  sentAt             DateTime?
  error              String?
  createdAt          DateTime          @default(now())
  /// pg-boss job id for cancel/reschedule; null for DRAFT rows not yet queued or legacy rows.
  pgBossJobId        String?
  /// Supabase Auth `user.id` of who created the schedule.
  createdByUserId    String?

  @@index([projectId, scheduledAt])
  @@index([campaignId])
}

/// Per-user UI preferences for a project (e.g. last selected WhatsApp group).
model UserProjectPreference {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lastGroupJid  String?
  lastGroupName String?
  updatedAt     DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([userId])
}

/// Per-project whatsmeow SQLite session (bytea). whatsmeow runs against a local file; we
/// hydrate/persist this row so sessions survive deploys without direct Postgres / search_path.
model WhatsAppSessionBlob {
  projectId String   @id
  data      Bytes
  updatedAt DateTime @updatedAt
}
