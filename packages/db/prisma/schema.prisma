generator client {
  provider = "prisma-client-js"
}

// Run: `npm run db:seed` from repo root (after migrate).

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  POST
  POLL
}

enum MessageStatus {
  PENDING
  SENDING
  SENT
  FAILED
  DRAFT
  CANCELLED
}

model Project {
  id               String                  @id @default(cuid())
  name             String
  description      String?
  createdAt        DateTime                @default(now())
  messages         ScheduledMessage[]
  notifyRecipients NotifyRecipient[]
  members          ProjectMember[]
  userPreferences  UserProjectPreference[]
}

// Links a Supabase Auth user id to a Project (see API X-Project-Id membership checks).
model ProjectMember {
  id        String   @id @default(cuid())
  // Supabase Auth user id (JWT `sub` / session `user.id`).
  userId    String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, projectId])
  @@index([userId])
}

model NotifyRecipient {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  waNumber  String
  label     String?

  @@index([projectId])
}

model ScheduledMessage {
  id               String        @id @default(cuid())
  projectId        String
  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groupJid         String
  groupName        String
  type             MessageType
  copyText         String?
  imageUrl         String?
  pollQuestion     String?
  pollOptions      String[]      @default([])
  pollMultiSelect  Boolean       @default(false)
  scheduledAt      DateTime
  status           MessageStatus @default(PENDING)
  sentAt           DateTime?
  error            String?
  createdAt        DateTime      @default(now())
  /// pg-boss job id for cancel/reschedule; null for DRAFT rows not yet queued or legacy rows.
  pgBossJobId      String?
  /// Supabase Auth `user.id` of who created the schedule.
  createdByUserId  String?

  @@index([projectId, scheduledAt])
}

/// Per-user UI preferences for a project (e.g. last selected WhatsApp group).
model UserProjectPreference {
  id            String   @id @default(cuid())
  userId        String
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lastGroupJid  String?
  lastGroupName String?
  updatedAt     DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([userId])
}
